# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Claude Code — personal/per-user settings. The team-shared file is
# .claude/settings.json (tracked); .local.json is for individual
# permission grants and is ignored by convention.
.claude/settings.local.json

# Codex compatibility mirror. On Windows this is a local junction to
# .claude/skills so Codex can discover repo skills without duplicating them.
.agents/

# QUL mushaf rendering assets. A contributor downloads these from
# qul.tarteel.ai into assets/qul/ per the README setup step; they are never
# committed (third-party fonts + databases, ~70 MB). pubspec.yaml declares the
# three files the build needs — qpc-v4-tajweed-15-lines.db, qpc-v4.db,
# ttf.zip — so `flutter build` bundles them into the binary.
assets/qul/
